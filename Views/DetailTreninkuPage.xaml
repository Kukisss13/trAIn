<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:h="clr-namespace:TreninkovyPlanovac.Helpers"
             x:Class="TreninkovyPlanovac.Views.DetailTreninkuPage"
             BackgroundColor="{DynamicResource DarkBg}"
             Shell.NavBarIsVisible="False">

    <Grid RowDefinitions="Auto,Auto,*,Auto" Padding="20,40,20,20">

        <!-- Zpět + Hlavička -->
        <Grid Grid.Row="0" ColumnDefinitions="Auto,*" Margin="0,0,0,15">
            <Frame Grid.Column="0"
                   BackgroundColor="{DynamicResource CardBg}"
                   CornerRadius="12"
                   WidthRequest="42" HeightRequest="42"
                   Padding="0"
                   BorderColor="Transparent">
                <Frame.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnZpetClicked" />
                </Frame.GestureRecognizers>
                <Label Text="‹" FontSize="24" TextColor="{DynamicResource TextPrimary}"
                       HorizontalOptions="Center" VerticalOptions="Center" />
            </Frame>
            <VerticalStackLayout Grid.Column="1" VerticalOptions="Center" Padding="15,0,0,0">
                <Label x:Name="NazevLabel"
                       FontSize="22" FontAttributes="Bold" TextColor="{DynamicResource TextPrimary}" />
                <Label x:Name="DatumLabel"
                       FontSize="13" TextColor="{DynamicResource TextTertiary}" />
            </VerticalStackLayout>
        </Grid>

        <!-- Hlavička tabulky -->
        <Frame Grid.Row="1" BackgroundColor="{DynamicResource CardBgLight}"
               CornerRadius="10" Padding="14,10"
               BorderColor="Transparent" Margin="0,0,0,8">
            <Grid ColumnDefinitions="3*,Auto,2*,Auto">
                <Label Grid.Column="0" Text="{Binding [Exercise], Source={x:Static h:Loc.Instance}}" FontSize="12" FontAttributes="Bold"
                       TextColor="{DynamicResource TextSecondary}" />
                <Label Grid.Column="1" Text="{Binding [Sets], Source={x:Static h:Loc.Instance}}" FontSize="12" FontAttributes="Bold"
                       TextColor="{DynamicResource TextSecondary}" WidthRequest="40" HorizontalTextAlignment="Center" />
                <Label Grid.Column="2" Text="{Binding [RepsWeight], Source={x:Static h:Loc.Instance}}" FontSize="12" FontAttributes="Bold"
                       TextColor="{DynamicResource TextSecondary}" HorizontalTextAlignment="Center" />
                <Label Grid.Column="3" Text="{Binding [Rest], Source={x:Static h:Loc.Instance}}" FontSize="12" FontAttributes="Bold"
                       TextColor="{DynamicResource TextSecondary}" WidthRequest="50" HorizontalTextAlignment="Center" />
            </Grid>
        </Frame>

        <!-- Seznam cviků -->
        <CollectionView Grid.Row="2" x:Name="PolozkyList" SelectionMode="None">
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <VerticalStackLayout>
                        <BoxView Color="{DynamicResource SeparatorColor}"
                                 HeightRequest="1"
                                 Margin="0,0,0,0"
                                 IsVisible="{Binding JeHlavicka}" />
                        <Grid ColumnDefinitions="3*,Auto,2*,Auto"
                              Padding="14,6" BackgroundColor="{DynamicResource CardBg}">
                            <Label Grid.Column="0" Text="{Binding NazevCviku}"
                                   FontSize="14" FontAttributes="Bold"
                                   TextColor="{DynamicResource TextPrimary}"
                                   LineBreakMode="TailTruncation"
                                   VerticalOptions="Center" />
                            <Label Grid.Column="1" Text="{Binding SerieText}"
                                   FontSize="13" TextColor="{DynamicResource TextTertiary}"
                                   WidthRequest="40" HorizontalTextAlignment="Center"
                                   VerticalOptions="Center" />
                            <Label Grid.Column="2" Text="{Binding RepyVahaText}"
                                   FontSize="14" TextColor="{StaticResource Primary}"
                                   HorizontalTextAlignment="Center"
                                   VerticalOptions="Center" />
                            <Label Grid.Column="3" Text="{Binding PauzaText}"
                                   FontSize="13" TextColor="{DynamicResource TextTertiary}"
                                   WidthRequest="50" HorizontalTextAlignment="Center"
                                   VerticalOptions="Center" />
                        </Grid>
                    </VerticalStackLayout>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

        <!-- Tlacitka -->
        <VerticalStackLayout Grid.Row="3" Spacing="10" Margin="0,10,0,0">
            <Button Text="{Binding [StartTraining], Source={x:Static h:Loc.Instance}}"
                    FontSize="17" FontAttributes="Bold"
                    HeightRequest="56"
                    CornerRadius="16"
                    BackgroundColor="{StaticResource Primary}"
                    TextColor="White"
                    Clicked="OnZacitTreninkClicked" />
            <Button Text="{Binding [DeleteTraining], Source={x:Static h:Loc.Instance}}"
                    FontSize="15"
                    HeightRequest="48"
                    CornerRadius="14"
                    BackgroundColor="#2A1515"
                    TextColor="#E94560"
                    Clicked="OnSmazatClicked" />
        </VerticalStackLayout>

    </Grid>

</ContentPage>
