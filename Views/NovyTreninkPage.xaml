<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:h="clr-namespace:TreninkovyPlanovac.Helpers"
             x:Class="TreninkovyPlanovac.Views.NovyTreninkPage"
             BackgroundColor="{DynamicResource DarkBg}"
             Shell.NavBarIsVisible="False">

    <Grid RowDefinitions="Auto,*" Padding="20,40,20,20">

        <!-- Zpět + Hlavička -->
        <Grid Grid.Row="0" ColumnDefinitions="Auto,*" Margin="0,0,0,20">
            <Frame Grid.Column="0"
                   BackgroundColor="{DynamicResource CardBg}"
                   CornerRadius="12"
                   WidthRequest="42" HeightRequest="42"
                   Padding="0"
                   BorderColor="Transparent">
                <Frame.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnZpetClicked" />
                </Frame.GestureRecognizers>
                <Label Text="‹" FontSize="24" TextColor="{DynamicResource TextPrimary}"
                       HorizontalOptions="Center" VerticalOptions="Center" />
            </Frame>
            <Label Grid.Column="1" Text="{Binding [NewTraining], Source={x:Static h:Loc.Instance}}"
                   FontSize="22" FontAttributes="Bold" TextColor="{DynamicResource TextPrimary}"
                   VerticalOptions="Center" Padding="15,0,0,0" />
        </Grid>

        <!-- Formulář -->
        <VerticalStackLayout Grid.Row="1" VerticalOptions="Center" Spacing="16" Padding="10,0">

            <Label Text="{Binding [NameYourTraining], Source={x:Static h:Loc.Instance}}"
                   FontSize="26" FontAttributes="Bold" TextColor="{DynamicResource TextPrimary}"
                   HorizontalOptions="Center" />
            <Label Text="{Binding [TrainingNameExample], Source={x:Static h:Loc.Instance}}"
                   FontSize="14" TextColor="{DynamicResource TextTertiary}"
                   HorizontalOptions="Center" />

            <Frame BackgroundColor="{DynamicResource CardBg}"
                   CornerRadius="14" Padding="4" BorderColor="Transparent"
                   Margin="0,10,0,0">
                <Entry x:Name="NazevEntry"
                       Placeholder="{Binding [TrainingNamePlaceholder], Source={x:Static h:Loc.Instance}}"
                       PlaceholderColor="{DynamicResource TextTertiary}"
                       TextColor="{DynamicResource TextPrimary}"
                       BackgroundColor="Transparent"
                       FontSize="18"
                       HorizontalTextAlignment="Center" />
            </Frame>

            <Frame BackgroundColor="{DynamicResource CardBg}"
                   CornerRadius="14" Padding="4" BorderColor="Transparent">
                <DatePicker x:Name="DatumPicker"
                            TextColor="{DynamicResource TextPrimary}"
                            BackgroundColor="Transparent"
                            FontSize="16"
                            HorizontalOptions="Center" />
            </Frame>

            <Button Text="{Binding [Continue], Source={x:Static h:Loc.Instance}}"
                    FontSize="17"
                    HeightRequest="54"
                    CornerRadius="14"
                    BackgroundColor="{StaticResource Primary}"
                    TextColor="{DynamicResource TextPrimary}"
                    FontAttributes="Bold"
                    Clicked="OnPokracovatClicked"
                    Margin="0,10,0,0" />
        </VerticalStackLayout>

    </Grid>

</ContentPage>
