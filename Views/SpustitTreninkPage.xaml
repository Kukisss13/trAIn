<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:h="clr-namespace:TreninkovyPlanovac.Helpers"
             x:Class="TreninkovyPlanovac.Views.SpustitTreninkPage"
             BackgroundColor="{DynamicResource DarkBg}"
             Shell.NavBarIsVisible="False">

    <Grid RowDefinitions="Auto,Auto,Auto,*,Auto" Padding="20,40,20,20">

        <!-- Header -->
        <Grid Grid.Row="0" ColumnDefinitions="Auto,*" Margin="0,0,0,10">
            <Frame Grid.Column="0"
                   BackgroundColor="{DynamicResource CardBg}"
                   CornerRadius="12"
                   WidthRequest="42" HeightRequest="42"
                   Padding="0"
                   BorderColor="Transparent">
                <Frame.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnZpetClicked" />
                </Frame.GestureRecognizers>
                <Label Text="&#x2190;" FontSize="22"
                       TextColor="{DynamicResource TextSecondary}"
                       HorizontalOptions="Center" VerticalOptions="Center" />
            </Frame>
            <VerticalStackLayout Grid.Column="1" VerticalOptions="Center" Padding="15,0,0,0">
                <Label x:Name="NazevLabel"
                       FontSize="22" FontAttributes="Bold"
                       TextColor="{DynamicResource TextPrimary}" />
                <Label Text="{Binding [TrainingInProgress], Source={x:Static h:Loc.Instance}}"
                       FontSize="13"
                       TextColor="{DynamicResource TextTertiary}" />
            </VerticalStackLayout>
        </Grid>

        <!-- Stopky + Kalorie -->
        <Frame Grid.Row="1"
               BackgroundColor="{DynamicResource CardBg}"
               CornerRadius="16" Padding="16,14"
               BorderColor="Transparent"
               Margin="0,0,0,15">
            <Grid ColumnDefinitions="*,Auto,*">
                <!-- Čas -->
                <HorizontalStackLayout Grid.Column="0" HorizontalOptions="Center" Spacing="8" VerticalOptions="Center">
                    <Label Text="&#x23F1;" FontSize="24" VerticalOptions="Center" />
                    <VerticalStackLayout VerticalOptions="Center">
                        <Label x:Name="StopkyLabel" Text="00:00"
                               FontSize="34" FontAttributes="Bold"
                               TextColor="{StaticResource Primary}" />
                        <Label Text="{Binding [Time], Source={x:Static h:Loc.Instance}}" FontSize="11"
                               TextColor="{DynamicResource TextTertiary}"
                               HorizontalOptions="Center" />
                    </VerticalStackLayout>
                </HorizontalStackLayout>
                <!-- Oddělovač -->
                <BoxView Grid.Column="1"
                         Color="{DynamicResource SeparatorColor}"
                         WidthRequest="1" HeightRequest="40"
                         VerticalOptions="Center" Margin="8,0" />
                <!-- Kalorie -->
                <HorizontalStackLayout Grid.Column="2" HorizontalOptions="Center" Spacing="8" VerticalOptions="Center">
                    <Label Text="&#x1F525;" FontSize="24" VerticalOptions="Center" />
                    <VerticalStackLayout VerticalOptions="Center">
                        <Label x:Name="KalorieLabel" Text="0"
                               FontSize="34" FontAttributes="Bold"
                               TextColor="#FF6B35" />
                        <Label Text="kcal" FontSize="11"
                               TextColor="{DynamicResource TextTertiary}"
                               HorizontalOptions="Center" />
                    </VerticalStackLayout>
                </HorizontalStackLayout>
            </Grid>
        </Frame>

        <!-- Hlavicka tabulky -->
        <Frame Grid.Row="2" BackgroundColor="{DynamicResource CardBgLight}"
               CornerRadius="10" Padding="14,10"
               BorderColor="Transparent" Margin="0,0,0,8">
            <Grid ColumnDefinitions="3*,Auto,2*,Auto,Auto">
                <Label Grid.Column="0" Text="{Binding [Exercise], Source={x:Static h:Loc.Instance}}" FontSize="12" FontAttributes="Bold"
                       TextColor="{DynamicResource TextSecondary}" />
                <Label Grid.Column="1" Text="{Binding [Sets], Source={x:Static h:Loc.Instance}}" FontSize="12" FontAttributes="Bold"
                       TextColor="{DynamicResource TextSecondary}" WidthRequest="40" HorizontalTextAlignment="Center" />
                <Label Grid.Column="2" Text="{Binding [RepsWeight], Source={x:Static h:Loc.Instance}}" FontSize="12" FontAttributes="Bold"
                       TextColor="{DynamicResource TextSecondary}" HorizontalTextAlignment="Center" />
                <Label Grid.Column="3" Text="" FontSize="12" WidthRequest="40" />
                <Label Grid.Column="4" Text="{Binding [Rest], Source={x:Static h:Loc.Instance}}" FontSize="12" FontAttributes="Bold"
                       TextColor="{DynamicResource TextSecondary}" WidthRequest="50" HorizontalTextAlignment="Center" />
            </Grid>
        </Frame>

        <!-- Seznam cviku -->
        <CollectionView Grid.Row="3" x:Name="PolozkyList" SelectionMode="None">
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <VerticalStackLayout>
                        <BoxView Color="{DynamicResource SeparatorColor}"
                                 HeightRequest="1"
                                 Margin="0,0,0,0"
                                 IsVisible="{Binding JeHlavicka}" />
                        <Grid ColumnDefinitions="3*,Auto,2*,Auto,Auto"
                              Padding="14,6" BackgroundColor="{DynamicResource CardBg}"
                              Opacity="{Binding RadekOpacity}">
                            <Label Grid.Column="0" Text="{Binding NazevCviku}"
                                   FontSize="14" FontAttributes="Bold"
                                   TextColor="{DynamicResource TextPrimary}"
                                   LineBreakMode="TailTruncation"
                                   VerticalOptions="Center" />
                            <Label Grid.Column="1" Text="{Binding SerieText}"
                                   FontSize="13" TextColor="{DynamicResource TextTertiary}"
                                   WidthRequest="40" HorizontalTextAlignment="Center"
                                   VerticalOptions="Center" />
                            <Label Grid.Column="2" Text="{Binding RepyVahaText}"
                                   FontSize="14" TextColor="{StaticResource Primary}"
                                   HorizontalTextAlignment="Center"
                                   VerticalOptions="Center" />
                            <!-- Fajfka -->
                            <Label Grid.Column="3"
                                   Text="&#x2714;"
                                   FontSize="22"
                                   TextColor="{Binding CheckTextColor}"
                                   WidthRequest="40"
                                   HorizontalTextAlignment="Center"
                                   VerticalOptions="Center">
                                <Label.GestureRecognizers>
                                    <TapGestureRecognizer Tapped="OnSerieOdkliknuta" />
                                </Label.GestureRecognizers>
                            </Label>
                            <Label Grid.Column="4" Text="{Binding PauzaText}"
                                   FontSize="13" TextColor="{DynamicResource TextTertiary}"
                                   WidthRequest="50" HorizontalTextAlignment="Center"
                                   VerticalOptions="Center" />
                        </Grid>
                    </VerticalStackLayout>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

        <!-- Odpocet pauzy -->
        <Frame Grid.Row="3"
               x:Name="PauzaOverlay"
               IsVisible="False"
               BackgroundColor="#E0181818"
               CornerRadius="20"
               Padding="30"
               BorderColor="{StaticResource Primary}"
               HasShadow="False"
               VerticalOptions="Center"
               HorizontalOptions="Center"
               ZIndex="10">
            <VerticalStackLayout Spacing="10" HorizontalOptions="Center">
                <Label Text="{Binding [Pause], Source={x:Static h:Loc.Instance}}"
                       FontSize="18" FontAttributes="Bold"
                       TextColor="{DynamicResource TextTertiary}"
                       HorizontalOptions="Center"
                       CharacterSpacing="3" />
                <Label x:Name="PauzaCountdownLabel"
                       Text="0:00"
                       FontSize="64" FontAttributes="Bold"
                       TextColor="{StaticResource Primary}"
                       HorizontalOptions="Center" />
                <Button Text="{Binding [SkipPause], Source={x:Static h:Loc.Instance}}"
                        FontSize="14" FontAttributes="Bold"
                        HeightRequest="42"
                        CornerRadius="12"
                        BackgroundColor="{DynamicResource CardBgLight}"
                        TextColor="{DynamicResource TextSecondary}"
                        Clicked="OnPreskocitPauzuClicked"
                        Margin="0,5,0,0" />
            </VerticalStackLayout>
        </Frame>

        <!-- Ukoncit trenink -->
        <Button Grid.Row="4"
                Text="{Binding [EndTraining], Source={x:Static h:Loc.Instance}}"
                FontSize="17" FontAttributes="Bold"
                HeightRequest="56"
                CornerRadius="16"
                BackgroundColor="{StaticResource Primary}"
                TextColor="White"
                Clicked="OnUkoncitClicked"
                Margin="0,10,0,0" />

    </Grid>

</ContentPage>
