<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:h="clr-namespace:TreninkovyPlanovac.Helpers"
             x:Class="TreninkovyPlanovac.Views.TreninkTabulkaPage"
             BackgroundColor="{DynamicResource DarkBg}"
             Shell.NavBarIsVisible="False">

    <Grid RowDefinitions="Auto,*" Padding="15,40,15,15">

        <!-- Zpět + Hlavička -->
        <Grid Grid.Row="0" ColumnDefinitions="Auto,*" Margin="5,0,5,12">
            <Frame Grid.Column="0"
                   BackgroundColor="{DynamicResource CardBg}"
                   CornerRadius="12"
                   WidthRequest="42" HeightRequest="42"
                   Padding="0"
                   BorderColor="Transparent">
                <Frame.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnZpetClicked" />
                </Frame.GestureRecognizers>
                <Label Text="‹" FontSize="24" TextColor="{DynamicResource TextPrimary}"
                       HorizontalOptions="Center" VerticalOptions="Center" />
            </Frame>
            <VerticalStackLayout Grid.Column="1" VerticalOptions="Center" Padding="15,0,0,0">
                <Label x:Name="NazevLabel"
                       FontSize="20" FontAttributes="Bold" TextColor="{DynamicResource TextPrimary}" />
                <Label x:Name="DatumLabel"
                       FontSize="13" TextColor="{DynamicResource TextTertiary}" />
            </VerticalStackLayout>
        </Grid>

        <!-- Hlavní obsah: Tabulka vlevo + Chat vpravo -->
        <Grid Grid.Row="1" ColumnDefinitions="*,340" ColumnSpacing="12">

            <!-- LEVÁ STRANA — Tabulka + Uložit -->
            <Grid Grid.Column="0" RowDefinitions="*,Auto">
                <ScrollView Grid.Row="0">
                    <ScrollView Orientation="Horizontal" HorizontalScrollBarVisibility="Always">
                        <VerticalStackLayout x:Name="TabulkaStack" Spacing="0" />
                    </ScrollView>
                </ScrollView>

                <Button Grid.Row="1"
                        Text="{Binding [SaveTraining], Source={x:Static h:Loc.Instance}}"
                        FontSize="16"
                        HeightRequest="50"
                        CornerRadius="14"
                        BackgroundColor="{StaticResource Primary}"
                        TextColor="{DynamicResource TextPrimary}"
                        FontAttributes="Bold"
                        Margin="0,10,0,0"
                        Clicked="OnUlozitClicked" />
            </Grid>

            <!-- PRAVÁ STRANA — AI Chat panel -->
            <Frame Grid.Column="1"
                   BackgroundColor="{DynamicResource CardBg}"
                   CornerRadius="16"
                   Padding="0"
                   BorderColor="Transparent"
                   HasShadow="False">
                <Grid RowDefinitions="Auto,*,Auto,Auto">

                    <!-- Chat hlavička -->
                    <Grid Grid.Row="0" Padding="16,14" ColumnDefinitions="Auto,*,Auto">
                        <Image Grid.Column="0"
                               Source="ikona.png"
                               WidthRequest="36" HeightRequest="36"
                               Aspect="AspectFill" />

                        <VerticalStackLayout Grid.Column="1" VerticalOptions="Center" Padding="10,0,0,0">
                            <Label Text="{Binding [AiTrainer], Source={x:Static h:Loc.Instance}}"
                                   FontSize="16" FontAttributes="Bold" TextColor="{DynamicResource TextPrimary}" />
                            <Label x:Name="ChatStatusLabel"
                                   Text="{Binding [ConsultTraining], Source={x:Static h:Loc.Instance}}"
                                   FontSize="11" TextColor="{DynamicResource TextTertiary}" />
                        </VerticalStackLayout>

                        <Frame Grid.Column="2"
                               BackgroundColor="Transparent"
                               CornerRadius="10"
                               Padding="6,4"
                               BorderColor="Transparent"
                               HasShadow="False">
                            <Frame.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnSmazatChatClicked" />
                            </Frame.GestureRecognizers>
                            <Label Text="🗑" FontSize="14"
                                   HorizontalOptions="Center" VerticalOptions="Center" />
                        </Frame>
                    </Grid>

                    <BoxView Grid.Row="0" Color="{DynamicResource SeparatorColor}"
                             HeightRequest="1" VerticalOptions="End" />

                    <!-- Chat zprávy -->
                    <CollectionView Grid.Row="1"
                                     x:Name="ZpravyCollection"
                                     ItemsUpdatingScrollMode="KeepLastItemInView"
                                     Margin="8,0">
                        <CollectionView.EmptyView>
                            <VerticalStackLayout VerticalOptions="Center"
                                                 HorizontalOptions="Center"
                                                 Padding="16" Spacing="10">
                                <Label Text="🤖" FontSize="36" HorizontalOptions="Center" />
                                <Label Text="{Binding [AskAnything], Source={x:Static h:Loc.Instance}}"
                                       FontSize="15" FontAttributes="Bold"
                                       TextColor="{DynamicResource TextPrimary}"
                                       HorizontalOptions="Center" />
                                <Label Text="{Binding [TrainingNutritionTech], Source={x:Static h:Loc.Instance}}"
                                       FontSize="12"
                                       TextColor="{DynamicResource TextTertiary}"
                                       HorizontalOptions="Center"
                                       HorizontalTextAlignment="Center" />

                                <FlexLayout Wrap="Wrap" JustifyContent="Center" Margin="0,4,0,0">
                                    <Frame BackgroundColor="#252545"
                                           CornerRadius="16" Padding="10,6"
                                           BorderColor="Transparent" HasShadow="False" Margin="3">
                                        <Frame.GestureRecognizers>
                                            <TapGestureRecognizer Tapped="OnNavrhClicked"
                                                CommandParameter="{Binding [SuggestWorkoutFull], Source={x:Static h:Loc.Instance}}" />
                                        </Frame.GestureRecognizers>
                                        <Label Text="{Binding [SuggestWorkout], Source={x:Static h:Loc.Instance}, StringFormat='💪 {0}'}" FontSize="11"
                                               TextColor="{DynamicResource TextSecondary}" />
                                    </Frame>
                                    <Frame BackgroundColor="#252545"
                                           CornerRadius="16" Padding="10,6"
                                           BorderColor="Transparent" HasShadow="False" Margin="3">
                                        <Frame.GestureRecognizers>
                                            <TapGestureRecognizer Tapped="OnNavrhClicked"
                                                CommandParameter="{Binding [ExerciseTechniqueFull], Source={x:Static h:Loc.Instance}}" />
                                        </Frame.GestureRecognizers>
                                        <Label Text="{Binding [ExerciseTechnique], Source={x:Static h:Loc.Instance}, StringFormat='🎯 {0}'}" FontSize="11"
                                               TextColor="{DynamicResource TextSecondary}" />
                                    </Frame>
                                    <Frame BackgroundColor="#252545"
                                           CornerRadius="16" Padding="10,6"
                                           BorderColor="Transparent" HasShadow="False" Margin="3">
                                        <Frame.GestureRecognizers>
                                            <TapGestureRecognizer Tapped="OnNavrhClicked"
                                                CommandParameter="{Binding [MotivateMeFull], Source={x:Static h:Loc.Instance}}" />
                                        </Frame.GestureRecognizers>
                                        <Label Text="{Binding [MotivateMe], Source={x:Static h:Loc.Instance}, StringFormat='⚡ {0}'}" FontSize="11"
                                               TextColor="{DynamicResource TextSecondary}" />
                                    </Frame>
                                </FlexLayout>
                            </VerticalStackLayout>
                        </CollectionView.EmptyView>

                        <CollectionView.ItemTemplate>
                            <DataTemplate>
                                <Grid Padding="4,3">
                                    <Frame IsVisible="{Binding JeUser}"
                                           BackgroundColor="{StaticResource Primary}"
                                           CornerRadius="14"
                                           Padding="12,8"
                                           BorderColor="Transparent"
                                           HasShadow="False"
                                           HorizontalOptions="End"
                                           MaximumWidthRequest="260">
                                        <Label Text="{Binding Obsah}"
                                               FontSize="13"
                                               TextColor="White"
                                               LineBreakMode="WordWrap" />
                                    </Frame>
                                    <Frame IsVisible="{Binding JeAssistant}"
                                           BackgroundColor="#252545"
                                           CornerRadius="14"
                                           Padding="12,8"
                                           BorderColor="Transparent"
                                           HasShadow="False"
                                           HorizontalOptions="Start"
                                           MaximumWidthRequest="260">
                                        <Label Text="{Binding Obsah}"
                                               FontSize="13"
                                               TextColor="{DynamicResource TextPrimary}"
                                               LineBreakMode="WordWrap" />
                                    </Frame>
                                </Grid>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>

                    <!-- Loading indicator -->
                    <HorizontalStackLayout Grid.Row="2"
                                            x:Name="ChatLoadingPanel"
                                            IsVisible="False"
                                            HorizontalOptions="Start"
                                            Padding="16,4" Spacing="6">
                        <ActivityIndicator IsRunning="True"
                                           Color="{StaticResource Primary}"
                                           WidthRequest="16" HeightRequest="16" />
                        <Label Text="{Binding [AiThinking], Source={x:Static h:Loc.Instance}}"
                               FontSize="11"
                               TextColor="{DynamicResource TextTertiary}"
                               VerticalOptions="Center" />
                    </HorizontalStackLayout>

                    <!-- Vstupní pole -->
                    <Grid Grid.Row="3" Padding="12,8" ColumnDefinitions="*,Auto"
                          ColumnSpacing="8" BackgroundColor="#151528">
                        <Frame Grid.Column="0"
                               BackgroundColor="#252545"
                               CornerRadius="12"
                               Padding="4,0"
                               BorderColor="Transparent">
                            <Entry x:Name="ChatVstup"
                                   Placeholder="{Binding [TypeMessage], Source={x:Static h:Loc.Instance}}"
                                   PlaceholderColor="{StaticResource Gray500}"
                                   TextColor="{DynamicResource TextPrimary}"
                                   BackgroundColor="Transparent"
                                   FontSize="14"
                                   ReturnType="Send"
                                   Completed="OnOdeslatChatClicked" />
                        </Frame>
                        <Frame Grid.Column="1"
                               BackgroundColor="{StaticResource Primary}"
                               CornerRadius="12"
                               WidthRequest="42" HeightRequest="42"
                               Padding="0"
                               BorderColor="Transparent">
                            <Frame.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnOdeslatChatClicked" />
                            </Frame.GestureRecognizers>
                            <Label Text="➤" FontSize="18" TextColor="White"
                                   HorizontalOptions="Center" VerticalOptions="Center" />
                        </Frame>
                    </Grid>

                </Grid>
            </Frame>

        </Grid>

    </Grid>

</ContentPage>
