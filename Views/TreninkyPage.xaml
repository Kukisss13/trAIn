<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:h="clr-namespace:TreninkovyPlanovac.Helpers"
             x:Class="TreninkovyPlanovac.Views.TreninkyPage"
             BackgroundColor="{DynamicResource DarkBg}"
             Shell.NavBarIsVisible="False">

    <Grid RowDefinitions="Auto,Auto,*" Padding="20,40,20,20">

        <!-- Zpět + Hlavička -->
        <Grid Grid.Row="0" ColumnDefinitions="Auto,*" Margin="0,0,0,15">
            <Frame Grid.Column="0"
                   BackgroundColor="{DynamicResource CardBg}"
                   CornerRadius="12"
                   WidthRequest="42" HeightRequest="42"
                   Padding="0"
                   BorderColor="Transparent">
                <Frame.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnZpetClicked" />
                </Frame.GestureRecognizers>
                <Label Text="‹" FontSize="24" TextColor="{DynamicResource TextPrimary}"
                       HorizontalOptions="Center" VerticalOptions="Center" />
            </Frame>
            <VerticalStackLayout Grid.Column="1" VerticalOptions="Center" Padding="15,0,0,0">
                <Label Text="{Binding [MyWorkouts], Source={x:Static h:Loc.Instance}}"
                       FontSize="22" FontAttributes="Bold" TextColor="{DynamicResource TextPrimary}" />
                <Label x:Name="PocetLabel"
                       Text="{Binding [Loading], Source={x:Static h:Loc.Instance}}"
                       FontSize="13" TextColor="{DynamicResource TextTertiary}" />
            </VerticalStackLayout>
        </Grid>

        <!-- Záložky: Tréninky / Tréninkové plány -->
        <Frame Grid.Row="1"
               BackgroundColor="{DynamicResource CardBg}"
               CornerRadius="14"
               Padding="4"
               BorderColor="Transparent"
               Margin="0,0,0,15">
            <Grid ColumnDefinitions="*,*,*" ColumnSpacing="4">
                <!-- Tab: Tréninky -->
                <Frame x:Name="TabTreninky"
                       Grid.Column="0"
                       BackgroundColor="{StaticResource Primary}"
                       CornerRadius="11"
                       Padding="0"
                       HeightRequest="40"
                       BorderColor="Transparent">
                    <Frame.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnTabTreninkyClicked" />
                    </Frame.GestureRecognizers>
                    <Label x:Name="TabTreninkyLabel"
                           Text="{Binding [Workouts], Source={x:Static h:Loc.Instance}}"
                           FontSize="13" FontAttributes="Bold"
                           TextColor="White"
                           HorizontalOptions="Center" VerticalOptions="Center" />
                </Frame>

                <!-- Tab: Tréninkové plány -->
                <Frame x:Name="TabPlany"
                       Grid.Column="1"
                       BackgroundColor="Transparent"
                       CornerRadius="11"
                       Padding="0"
                       HeightRequest="40"
                       BorderColor="Transparent">
                    <Frame.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnTabPlanyClicked" />
                    </Frame.GestureRecognizers>
                    <Label x:Name="TabPlanyLabel"
                           Text="{Binding [Plans], Source={x:Static h:Loc.Instance}}"
                           FontSize="13" FontAttributes="Bold"
                           TextColor="{DynamicResource TextTertiary}"
                           HorizontalOptions="Center" VerticalOptions="Center" />
                </Frame>

                <!-- Tab: Vytvořit plán -->
                <Frame x:Name="TabVytvorit"
                       Grid.Column="2"
                       BackgroundColor="Transparent"
                       CornerRadius="11"
                       Padding="0"
                       HeightRequest="40"
                       BorderColor="Transparent">
                    <Frame.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnTabVytvoritClicked" />
                    </Frame.GestureRecognizers>
                    <Label x:Name="TabVytvoritLabel"
                           Text="{Binding [CreateNew], Source={x:Static h:Loc.Instance}}"
                           FontSize="13" FontAttributes="Bold"
                           TextColor="{DynamicResource TextTertiary}"
                           HorizontalOptions="Center" VerticalOptions="Center" />
                </Frame>
            </Grid>
        </Frame>

        <!-- Obsah: Tréninky -->
        <Grid Grid.Row="2" x:Name="TreninkyContent">
            <CollectionView x:Name="TreninkyList" SelectionMode="None">
                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Frame BackgroundColor="{DynamicResource CardBg}"
                               CornerRadius="14"
                               Padding="0"
                               Margin="0,0,0,8"
                               BorderColor="Transparent">
                            <Frame.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnTreninkClicked"
                                                      CommandParameter="{Binding .}" />
                            </Frame.GestureRecognizers>
                            <Grid ColumnDefinitions="Auto,*,Auto" Padding="16,14">
                                <Frame Grid.Column="0"
                                       BackgroundColor="{DynamicResource IconBg}"
                                       CornerRadius="12"
                                       WidthRequest="50" HeightRequest="50"
                                       Padding="0"
                                       BorderColor="Transparent">
                                    <VerticalStackLayout HorizontalOptions="Center" VerticalOptions="Center">
                                        <Label Text="{Binding DenText}"
                                               FontSize="18" FontAttributes="Bold"
                                               TextColor="{StaticResource Primary}"
                                               HorizontalOptions="Center" />
                                        <Label Text="{Binding MesicText}"
                                               FontSize="10"
                                               TextColor="{DynamicResource TextTertiary}"
                                               HorizontalOptions="Center" />
                                    </VerticalStackLayout>
                                </Frame>
                                <VerticalStackLayout Grid.Column="1" VerticalOptions="Center" Padding="12,0,0,0">
                                    <Label Text="{Binding Nazev}"
                                           FontSize="16" FontAttributes="Bold"
                                           TextColor="{DynamicResource TextPrimary}" />
                                    <Label Text="{Binding PocetCvikuText}"
                                           FontSize="13"
                                           TextColor="{DynamicResource TextTertiary}" />
                                </VerticalStackLayout>
                                <Label Grid.Column="2"
                                       Text="›"
                                       FontSize="28"
                                       TextColor="{DynamicResource TextTertiary}"
                                       VerticalOptions="Center" />
                            </Grid>
                        </Frame>
                    </DataTemplate>
                </CollectionView.ItemTemplate>

                <CollectionView.EmptyView>
                    <VerticalStackLayout HorizontalOptions="Center" VerticalOptions="Center"
                                         Spacing="8" Padding="0,60,0,0">
                        <Label Text="{Binding [NoWorkouts], Source={x:Static h:Loc.Instance}}" FontSize="18"
                               TextColor="{DynamicResource TextTertiary}" HorizontalOptions="Center" />
                        <Label Text="{Binding [WorkoutsFromPlans], Source={x:Static h:Loc.Instance}}" FontSize="14"
                               TextColor="{DynamicResource TextTertiary}" HorizontalOptions="Center" />
                    </VerticalStackLayout>
                </CollectionView.EmptyView>
            </CollectionView>
        </Grid>

        <!-- Obsah: Tréninkové plány -->
        <Grid Grid.Row="2" x:Name="PlanyContent" IsVisible="False" RowDefinitions="*">

            <CollectionView Grid.Row="0" x:Name="PlanyList" SelectionMode="None">
                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Frame BackgroundColor="{DynamicResource CardBg}"
                               CornerRadius="14"
                               Padding="0"
                               Margin="0,0,0,8"
                               BorderColor="Transparent">
                            <Frame.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnPlanClicked"
                                                      CommandParameter="{Binding .}" />
                            </Frame.GestureRecognizers>
                            <Grid ColumnDefinitions="Auto,*,Auto,Auto" Padding="16,14">
                                <Frame Grid.Column="0"
                                       BackgroundColor="{DynamicResource IconBg}"
                                       CornerRadius="12"
                                       WidthRequest="50" HeightRequest="50"
                                       Padding="0"
                                       BorderColor="Transparent">
                                    <Label Text="&#x1F4DD;" FontSize="22"
                                           HorizontalOptions="Center" VerticalOptions="Center" />
                                </Frame>
                                <VerticalStackLayout Grid.Column="1" VerticalOptions="Center" Padding="12,0,0,0">
                                    <Label Text="{Binding NazevSKonceptem}"
                                           FontSize="16" FontAttributes="Bold"
                                           TextColor="{Binding KonceptBarva}" />
                                    <Label Text="{Binding PocetCvikuText}"
                                           FontSize="13"
                                           TextColor="{DynamicResource TextTertiary}" />
                                </VerticalStackLayout>
                                <Label Grid.Column="2"
                                       Text="›"
                                       FontSize="28"
                                       TextColor="{DynamicResource TextTertiary}"
                                       VerticalOptions="Center"
                                       Margin="0,0,8,0" />
                                <Frame Grid.Column="3"
                                       BackgroundColor="#2A1515"
                                       CornerRadius="10"
                                       WidthRequest="36" HeightRequest="36"
                                       Padding="0"
                                       BorderColor="Transparent"
                                       VerticalOptions="Center">
                                    <Frame.GestureRecognizers>
                                        <TapGestureRecognizer Tapped="OnSmazatPlanClicked"
                                                              CommandParameter="{Binding .}" />
                                    </Frame.GestureRecognizers>
                                    <Label Text="🗑" FontSize="16"
                                           HorizontalOptions="Center" VerticalOptions="Center" />
                                </Frame>
                            </Grid>
                        </Frame>
                    </DataTemplate>
                </CollectionView.ItemTemplate>

                <CollectionView.EmptyView>
                    <VerticalStackLayout HorizontalOptions="Center" VerticalOptions="Center"
                                         Spacing="8" Padding="0,60,0,0">
                        <Label Text="{Binding [NoPlans], Source={x:Static h:Loc.Instance}}" FontSize="18"
                               TextColor="{DynamicResource TextTertiary}" HorizontalOptions="Center" />
                        <Label Text="{Binding [CreateFirstPlan], Source={x:Static h:Loc.Instance}}" FontSize="14"
                               TextColor="{DynamicResource TextTertiary}" HorizontalOptions="Center" />
                    </VerticalStackLayout>
                </CollectionView.EmptyView>
            </CollectionView>

        </Grid>

        <!-- Obsah: Vytvořit plán -->
        <Grid Grid.Row="2" x:Name="VytvoritContent" IsVisible="False">
            <ScrollView>
                <VerticalStackLayout Spacing="16" Padding="0,20,0,0" VerticalOptions="Center">
                    <Label Text="{Binding [CreateNewPlan], Source={x:Static h:Loc.Instance}}"
                           FontSize="26" FontAttributes="Bold"
                           TextColor="{DynamicResource TextPrimary}"
                           HorizontalOptions="Center" />
                    <Label Text="{Binding [NamePlanDesc], Source={x:Static h:Loc.Instance}}"
                           FontSize="14"
                           TextColor="{DynamicResource TextTertiary}"
                           HorizontalOptions="Center" />

                    <Frame BackgroundColor="{DynamicResource CardBg}"
                           CornerRadius="14" Padding="4" BorderColor="Transparent"
                           Margin="0,10,0,0">
                        <Entry x:Name="NazevEntry"
                               Placeholder="{Binding [PlanNamePlaceholder], Source={x:Static h:Loc.Instance}}"
                               PlaceholderColor="{DynamicResource TextTertiary}"
                               TextColor="{DynamicResource TextPrimary}"
                               BackgroundColor="Transparent"
                               FontSize="18"
                               HorizontalTextAlignment="Center" />
                    </Frame>

                    <Frame BackgroundColor="{DynamicResource CardBg}"
                           CornerRadius="14" Padding="4" BorderColor="Transparent">
                        <DatePicker x:Name="DatumPicker"
                                    TextColor="{DynamicResource TextPrimary}"
                                    BackgroundColor="Transparent"
                                    FontSize="16"
                                    HorizontalOptions="Center" />
                    </Frame>

                    <Frame BackgroundColor="{StaticResource Primary}"
                           CornerRadius="14"
                           Padding="0"
                           HeightRequest="54"
                           BorderColor="Transparent"
                           Margin="0,10,0,0">
                        <Frame.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnVytvoritPlanClicked" />
                        </Frame.GestureRecognizers>
                        <HorizontalStackLayout HorizontalOptions="Center" VerticalOptions="Center" Spacing="10">
                            <Label Text="+" FontSize="24" FontAttributes="Bold" TextColor="White" />
                            <Label Text="{Binding [CreatePlan], Source={x:Static h:Loc.Instance}}" FontSize="17" FontAttributes="Bold" TextColor="White"
                                   VerticalOptions="Center" />
                        </HorizontalStackLayout>
                    </Frame>
                </VerticalStackLayout>
            </ScrollView>
        </Grid>

    </Grid>

</ContentPage>
