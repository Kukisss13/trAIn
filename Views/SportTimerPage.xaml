<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:h="clr-namespace:TreninkovyPlanovac.Helpers"
             x:Class="TreninkovyPlanovac.Views.SportTimerPage"
             BackgroundColor="{DynamicResource DarkBg}"
             Shell.NavBarIsVisible="False">

    <Grid RowDefinitions="Auto,*,Auto" Padding="20,40,20,20">

        <!-- Header -->
        <Grid Grid.Row="0" ColumnDefinitions="Auto,*" Margin="0,0,0,30">
            <Frame Grid.Column="0"
                   BackgroundColor="{DynamicResource CardBg}"
                   CornerRadius="12"
                   WidthRequest="42" HeightRequest="42"
                   Padding="0"
                   BorderColor="Transparent">
                <Frame.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnZpetClicked" />
                </Frame.GestureRecognizers>
                <Label Text="&#x2190;" FontSize="22"
                       TextColor="{DynamicResource TextSecondary}"
                       HorizontalOptions="Center" VerticalOptions="Center" />
            </Frame>
            <VerticalStackLayout Grid.Column="1" VerticalOptions="Center" Padding="15,0,0,0">
                <Label x:Name="SportIkonaNazevLabel"
                       FontSize="22" FontAttributes="Bold"
                       TextColor="{DynamicResource TextPrimary}" />
                <Label x:Name="HeaderSubtitleLabel"
                       Text="{Binding [GetReady], Source={x:Static h:Loc.Instance}}"
                       FontSize="13"
                       TextColor="{DynamicResource TextTertiary}" />
            </VerticalStackLayout>
        </Grid>

        <!-- Středová sekce: čas + vzdálenost + kalorie -->
        <VerticalStackLayout Grid.Row="1" VerticalOptions="Center" Spacing="16">

            <!-- Stopky -->
            <Frame BackgroundColor="{DynamicResource CardBg}"
                   CornerRadius="20" Padding="30,24"
                   BorderColor="Transparent">
                <VerticalStackLayout Spacing="4" HorizontalOptions="Center">
                    <Label Text="&#x23F1;" FontSize="30" HorizontalOptions="Center" />
                    <Label x:Name="StopkyLabel" Text="00:00"
                           FontSize="64" FontAttributes="Bold"
                           TextColor="{StaticResource Primary}"
                           HorizontalOptions="Center" />
                    <Label Text="{Binding [TrainingTime], Source={x:Static h:Loc.Instance}}"
                           FontSize="13"
                           TextColor="{DynamicResource TextTertiary}"
                           HorizontalOptions="Center" />
                </VerticalStackLayout>
            </Frame>

            <!-- Vzdálenost (jen pro beh/chuze/kolo) -->
            <Frame x:Name="VzdalenostFrame"
                   BackgroundColor="{DynamicResource CardBg}"
                   CornerRadius="20" Padding="30,20"
                   BorderColor="Transparent"
                   IsVisible="False">
                <Grid ColumnDefinitions="*,Auto,*">
                    <!-- Vzdálenost -->
                    <VerticalStackLayout Grid.Column="0" Spacing="3" HorizontalOptions="Center">
                        <Label Text="&#x1F4CD;" FontSize="26" HorizontalOptions="Center" />
                        <Label x:Name="VzdalenostLabel" Text="0.00"
                               FontSize="40" FontAttributes="Bold"
                               TextColor="#4CAF50"
                               HorizontalOptions="Center" />
                        <Label Text="km" FontSize="12"
                               TextColor="{DynamicResource TextTertiary}"
                               HorizontalOptions="Center" />
                    </VerticalStackLayout>
                    <!-- Oddělovač -->
                    <BoxView Grid.Column="1" WidthRequest="1" BackgroundColor="{DynamicResource SeparatorColor}"
                             VerticalOptions="Fill" Margin="10,4" />
                    <!-- Tempo -->
                    <VerticalStackLayout Grid.Column="2" Spacing="3" HorizontalOptions="Center">
                        <Label Text="&#x26A1;" FontSize="26" HorizontalOptions="Center" />
                        <Label x:Name="TempoLabel" Text="--:--"
                               FontSize="40" FontAttributes="Bold"
                               TextColor="#2196F3"
                               HorizontalOptions="Center" />
                        <Label x:Name="TempoJednotkaLabel" Text="min/km"
                               FontSize="12"
                               TextColor="{DynamicResource TextTertiary}"
                               HorizontalOptions="Center" />
                    </VerticalStackLayout>
                </Grid>
            </Frame>

            <!-- Kalorie + Tep -->
            <Frame BackgroundColor="{DynamicResource CardBg}"
                   CornerRadius="20" Padding="20,20"
                   BorderColor="Transparent">
                <Grid ColumnDefinitions="*,Auto,*">
                    <!-- Kalorie -->
                    <VerticalStackLayout Grid.Column="0" Spacing="3" HorizontalOptions="Center">
                        <Label Text="&#x1F525;" FontSize="26" HorizontalOptions="Center" />
                        <Label x:Name="KalorieLabel" Text="0"
                               FontSize="40" FontAttributes="Bold"
                               TextColor="#FF6B35"
                               HorizontalOptions="Center" />
                        <Label Text="kcal" FontSize="12"
                               TextColor="{DynamicResource TextTertiary}"
                               HorizontalOptions="Center" />
                    </VerticalStackLayout>
                    <!-- Oddělovač -->
                    <BoxView Grid.Column="1" WidthRequest="1" BackgroundColor="{DynamicResource SeparatorColor}"
                             VerticalOptions="Fill" Margin="10,4" />
                    <!-- Tep -->
                    <VerticalStackLayout Grid.Column="2" Spacing="3" HorizontalOptions="Center">
                        <Label Text="&#x2764;" FontSize="26" HorizontalOptions="Center"
                               TextColor="#888" />
                        <Label Text="--"
                               FontSize="40" FontAttributes="Bold"
                               TextColor="#888"
                               HorizontalOptions="Center" />
                        <Label Text="bpm"
                               FontSize="12"
                               TextColor="{DynamicResource TextTertiary}"
                               HorizontalOptions="Center" />
                        <Label Text="{Binding [SoonWithWatch], Source={x:Static h:Loc.Instance}}"
                               FontSize="10"
                               TextColor="{DynamicResource TextTertiary}"
                               HorizontalOptions="Center" />
                    </VerticalStackLayout>
                </Grid>
            </Frame>

            <!-- Info o výpočtu -->
            <Label x:Name="InfoLabel"
                   FontSize="12"
                   TextColor="{DynamicResource TextTertiary}"
                   HorizontalOptions="Center"
                   HorizontalTextAlignment="Center" />

        </VerticalStackLayout>

        <!-- Ukončit -->
        <Button Grid.Row="2"
                x:Name="UkoncitButton"
                Text="{Binding [EndWorkout], Source={x:Static h:Loc.Instance}}"
                FontSize="17" FontAttributes="Bold"
                HeightRequest="56"
                CornerRadius="16"
                BackgroundColor="{StaticResource Primary}"
                TextColor="White"
                Clicked="OnUkoncitClicked"
                Margin="0,10,0,0"
                IsVisible="False" />

        <!-- Start overlay -->
        <Grid x:Name="StartOverlay"
              Grid.RowSpan="3"
              BackgroundColor="{DynamicResource DarkBg}"
              IsVisible="True">

            <VerticalStackLayout VerticalOptions="Center" HorizontalOptions="Center" Spacing="20">
                <Label x:Name="StartSportIkona"
                       FontSize="80"
                       HorizontalOptions="Center" />
                <Label x:Name="StartSportNazev"
                       FontSize="32" FontAttributes="Bold"
                       TextColor="{DynamicResource TextPrimary}"
                       HorizontalOptions="Center" />
                <Label Text="{Binding [AreYouReady], Source={x:Static h:Loc.Instance}}"
                       FontSize="16"
                       TextColor="{DynamicResource TextTertiary}"
                       HorizontalOptions="Center"
                       Margin="0,0,0,20" />
                <Button Text="{Binding [StartWorkoutBtn], Source={x:Static h:Loc.Instance}}"
                        FontSize="20" FontAttributes="Bold"
                        HeightRequest="64"
                        WidthRequest="280"
                        CornerRadius="20"
                        BackgroundColor="{StaticResource Primary}"
                        TextColor="White"
                        Clicked="OnStartWorkoutClicked" />
            </VerticalStackLayout>
        </Grid>

    </Grid>

</ContentPage>
